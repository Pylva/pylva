{
  "name": "pylva",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "dev:services": "docker compose -f docker/docker-compose.yml up -d",
    "dev:services:down": "docker compose -f docker/docker-compose.yml down",
    "dev:services:reset": "docker compose -f docker/docker-compose.yml down -v",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:frontend": "vitest run --config vitest.frontend.config.ts",
    "test:e2e": "playwright test",
    "check:external-egress": "tsx scripts/check-external-egress.ts",
    "perf:budget": "tsx scripts/assert-performance-budget.ts",
    "license:check": "node scripts/oss-export/check-license-map.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,css,json}\"",
    "typecheck": "tsc -b",
    "db:setup": "ALLOW_MIGRATION_DATABASE_URL_FALLBACK=true tsx db/setup.ts",
    "db:apply:migration": "ALLOW_MIGRATION_DATABASE_URL_FALLBACK=true tsx scripts/apply-postgres-migration.ts",
    "db:manifest": "tsx scripts/generate-migration-manifest.ts",
    "db:migrate": "ALLOW_MIGRATION_DATABASE_URL_FALLBACK=true tsx scripts/db-migrate.ts",
    "db:migrate:status": "ALLOW_MIGRATION_DATABASE_URL_FALLBACK=true tsx scripts/db-migrate.ts --status",
    "db:migrate:verify-physical": "ALLOW_MIGRATION_DATABASE_URL_FALLBACK=true tsx scripts/verify-physical-schema-contract.ts",
    "db:setup:clickhouse": "SKIP_POSTGRES=true pnpm db:setup",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "ALLOW_MIGRATION_DATABASE_URL_FALLBACK=true tsx db/setup.ts && tsx db/seed.ts",
    "clickhouse:doctor": "tsx scripts/clickhouse-doctor.ts",
    "budget-control:doctor": "tsx scripts/authoritative-budget-control-doctor.ts",
    "budget:readiness": "tsx scripts/budget-readiness.ts",
    "clickhouse:provision-budget-rbac": "tsx scripts/provision-authoritative-budget-clickhouse-rbac.ts",
    "clickhouse:backfill-customer-daily": "tsx scripts/backfill-cost-customer-daily-agg.ts",
    "clickhouse:backfill-daily-agg-v2": "tsx scripts/backfill-cost-daily-agg-v2.ts",
    "clickhouse:backfill-model-daily": "tsx scripts/backfill-cost-model-daily-agg.ts",
    "clickhouse:backfill-pricing-v2-aggregates": "pnpm clickhouse:backfill-daily-agg-v2 && pnpm clickhouse:backfill-customer-daily",
    "cli:create-builder": "tsx scripts/cli/create-builder.ts",
    "cli:create-api-key": "tsx scripts/cli/create-api-key.ts",
    "cron:backfill-pending-prices": "tsx scripts/backfill-pending-prices.ts",
    "cron:reconcile-cost-daily-agg": "tsx scripts/reconcile-cost-daily-agg.ts"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1090.0",
    "@aws-sdk/client-secrets-manager": "^3.1090.0",
    "@clickhouse/client": "^1.23.1",
    "@pylva/shared": "workspace:*",
    "@sentry/nextjs": "^10.66.0",
    "@t3-oss/env-core": "^0.13.0",
    "arctic": "^2.3.4",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "next": "15.5.18",
    "opossum": "^10.0.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^5.0.1",
    "resend": "^4.8.0",
    "stripe": "^17.7.0",
    "undici": "7.28.0",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@langchain/langgraph": "^1.4.8",
    "@opennextjs/aws": "4.0.3",
    "@playwright/test": "^1.61.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/opossum": "^8.1.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "autoprefixer": "^10.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.25.0",
    "msw": "^2.15.0",
    "pino-pretty": "^11.3.0",
    "postcss": "^8.5.20",
    "prettier": "3.9.5",
    "size-limit": "^11.1.6",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^4.3.3",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^6.0.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.10"
  }
}
