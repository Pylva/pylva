# PostgreSQL
DATABASE_URL=postgresql://pylva:pylva_dev@localhost:5432/pylva

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123

# Redis
REDIS_URL=redis://localhost:6379

# JWT Keys (dev — run scripts/generate-dev-keys.ts to create)
JWT_PRIVATE_KEY=.keys/private.pem
JWT_PUBLIC_KEY=.keys/public.pem

# argon2 pepper. In production this MUST NOT be the dev default and must be
# >= 32 bytes (the app refuses to boot otherwise). Generate: openssl rand -hex 32
ARGON2_SECRET=dev-secret-change-in-prod

# Dedicated HMAC key for OAuth state signing (decoupled from ARGON2_SECRET).
# Optional; falls back to ARGON2_SECRET if unset. Generate: openssl rand -hex 32
# OAUTH_STATE_SECRET=

# Node environment
NODE_ENV=development

# Public backend URL (used for webhook + alert deep-link construction)
PYLVA_BACKEND_URL=http://localhost:3000

# Log level (trace | debug | info | warn | error | fatal | silent)
LOG_LEVEL=info

# Internal Slack drift-alert webhook (B1 team-notify — NOT the user-facing
# Slack channel from B2a; that lives per-rule in rule_alert_channels)
# SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional AWS Lambda used by VPC runtimes for allowlisted public HTTPS egress.
# Leave unset for direct egress. The runtime role needs lambda:InvokeFunction
# permission scoped to this function when it is configured.
# EGRESS_BROKER_FUNCTION_NAME=pylva-staging-public-api-egress-broker

# Cron bearer secret (EventBridge → ECS task invocation, B2a D1)
# Generate with: openssl rand -hex 32
# CRON_SECRET=change-me-at-least-32-chars-long-abcdef

# Stripe (B2b — billing)
# Get keys from https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_CONNECT_CLIENT_ID=ca_...
# Webhook-signing secret (stripe listen --forward-to .../api/v1/billing/webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Pin Stripe API version — review cadence is tracked internally.
# STRIPE_API_VERSION=2024-11-20.acacia
# Billing currency (USD only in B2b; multi-currency deferred)
# BILLING_DEFAULT_CURRENCY=usd

# --- B2a: OAuth (arctic) ---
# GitHub OAuth app: https://github.com/settings/applications/new
# Callback URL: ${OAUTH_REDIRECT_BASE_URL}/api/v1/auth/oauth/github/callback
# GITHUB_OAUTH_CLIENT_ID=Iv1.xxxxxxxxxxxx
# GITHUB_OAUTH_CLIENT_SECRET=
# Google OAuth app: https://console.cloud.google.com/apis/credentials
# Callback URL: ${OAUTH_REDIRECT_BASE_URL}/api/v1/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=

# Base URL used for OAuth callbacks + invite links + alert deep-links, and as
# the origin for login redirects from protected pages (e.g. /settings/keys,
# /o/{slug}/*). Set it to your public origin: redirects are built from this
# value, never from the incoming request host.
# Must match the registered OAuth app's callback origin in production.
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# --- B2a: Email (Resend) ---
# Get key: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx
MAGIC_LINK_FROM_EMAIL=login@pylva.local
MAGIC_LINK_TTL_SECONDS=900
INVITE_FROM_EMAIL=team@pylva.local
INVITE_TTL_HOURS=168
ALERT_FROM_EMAIL=alerts@pylva.local
# Concierge custom-rule-request internal notification recipient. Leave UNSET on
# self-host: the request is stored locally and nothing is emailed to Pylva.
# Pylva Cloud sets this to its internal address.
# CUSTOM_RULE_REQUEST_EMAIL=

# --- B2a: Sentry (optional in dev) ---
# SENTRY_DSN=https://xxx@oxxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=dev

# Optional product analytics. Leave the key empty to keep PostHog disabled.
# Only the allowlisted HTTPS PostHog Cloud hosts are accepted by the app.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- B2a: Session cookies ---
SESSION_COOKIE_NAME=pylva_session
SESSION_COOKIE_SECURE=false

# --- B3: Feature kill switches (D12) ---
ENABLE_SIMULATOR=true
ENABLE_SSE_FEED=false
ENABLE_COST_SOURCES=true
# Optional self-host cap. Disabled by default so Pylva Cloud plan limits do not
# apply to local/self-hosted builders.
ENABLE_EVENT_LIMITS=false
